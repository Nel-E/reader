<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Reader"
        android:usesCleartextTraffic="true">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.Reader">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- Open .md files: content URI with text/markdown MIME type -->
            <intent-filter android:priority="100">
                <action android:name="android.intent.action.VIEW" />
                <action android:name="android.intent.action.EDIT" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:scheme="content" android:mimeType="text/markdown" />
                <data android:scheme="content" android:mimeType="text/x-markdown" />
            </intent-filter>

            <!-- Open .md files: content URI with generic text/* MIME type -->
            <intent-filter android:priority="50">
                <action android:name="android.intent.action.VIEW" />
                <action android:name="android.intent.action.EDIT" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:scheme="content" android:mimeType="text/*"
                    android:pathPattern=".*\.md" />
                <data android:scheme="content" android:mimeType="application/octet-stream"
                    android:pathPattern=".*\.md" />
            </intent-filter>

            <!-- Open .md files: file URI (legacy, Android ≤ 6) -->
            <intent-filter android:priority="50">
                <action android:name="android.intent.action.VIEW" />
                <action android:name="android.intent.action.EDIT" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:scheme="file" android:mimeType="text/markdown"
                    android:host="*" android:pathPattern=".*\.md" />
                <data android:scheme="file" android:mimeType="text/*"
                    android:host="*" android:pathPattern=".*\.md" />
            </intent-filter>
        </activity>
    </application>

</manifest>
